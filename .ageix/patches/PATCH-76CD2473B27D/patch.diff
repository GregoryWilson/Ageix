+from __future__ import annotations
+
+import subprocess
+import time
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any, Dict, Optional
+
+from services.patch_validation_registry import PatchValidationRecord, PatchValidationRegistry
+
+
+@dataclass(frozen=True)
+class WorkerContext:
+    project_id: str
+    agent_id: str = "unknown"
+    session_id: str = "unknown"
+    metadata: Dict[str, Any] | None = None
+
+
+class PatchValidationWorker:
+    """Validate stored patch artifacts with `git apply --check` only.
+
+    This worker intentionally does not apply patches, run tests, mutate the
+    repository, change branches, stage files, or execute arbitrary commands.
+    """
+
+    def __init__(
+        self,
+        *,
+        repo_root: Path | str = ".",
+        patch_root: Path | str = ".ageix/patches",
+        validation_registry: Optional[PatchValidationRegistry] = None,
+        timeout_seconds: int = 30,
+        artifact_registry: Any = None,
+        audit_sink: Any = None,
+    ) -> None:
+        self.repo_root = Path(repo_root)
+        self.patch_root = Path(patch_root)
+        self.validation_registry = validation_registry or PatchValidationRegistry(self.repo_root / ".ageix" / "patch_validations")
+        self.timeout_seconds = int(timeout_seconds)
+        self.artifact_registry = artifact_registry
+        self.audit_sink = audit_sink
+
+    def validate(self, *, patch_id: str, context: Optional[WorkerContext] = None) -> Dict[str, Any]:
+        started = time.monotonic()
+        started_at = self._now_iso()
+        stdout = ""
+        stderr = ""
+        exit_code: Optional[int] = None
+        artifact_id: Optional[str] = None
+
+        try:
+            patch_path = self._resolve_stored_patch(patch_id)
+            completed = subprocess.run(
+                ["git", "apply", "--check", str(patch_path)],
+                cwd=str(self.repo_root),
+                text=True,
+                capture_output=True,
+                shell=False,
+                timeout=self.timeout_seconds,
+                check=False,
+            )
+            stdout = completed.stdout or ""
+            stderr = completed.stderr or ""
+            exit_code = completed.returncode
+            if completed.returncode == 0:
+                status = "passed"
+                summary = "Patch validated successfully."
+            else:
+                status = "failed"
+                summary = "Patch validation failed."
+        except subprocess.TimeoutExpired as exc:
+            stdout = exc.stdout if isinstance(exc.stdout, str) else ""
+            stderr = exc.stderr if isinstance(exc.stderr, str) else ""
+            status = "error"
+            summary = "Patch validation timed out."
+        except Exception as exc:  # infrastructure/registry errors are error, not failed
+            status = "error"
+            summary = str(exc)
+
+        duration_ms = int((time.monotonic() - started) * 1000)
+        record = self.validation_registry.create(
+            patch_id=patch_id,
+            status=status,
+            summary=summary,
+            stdout=stdout,
+            stderr=stderr,
+            artifact_id=artifact_id,
+            exit_code=exit_code,
+            started_at=started_at,
+            completed_at=self._now_iso(),
+            duration_ms=duration_ms,
+            metadata={"worker": "PatchValidationWorker", "version": "19.6", "context": self._context_payload(context)},
+        )
+
+        artifact_id = self._register_artifact(record)
+        if artifact_id:
+            record_path = self.validation_registry.root / record.patch_validation_id / "result.json"
+            payload = record.to_dict()
+            payload["artifact_id"] = artifact_id
+            record_path.write_text(self._json_dumps(payload), encoding="utf-8")
+            record = PatchValidationRecord.from_dict(payload)
+
+        self._audit(record, context=context)
+        return record.to_dict()
+
+    def get(self, *, patch_validation_id: str) -> Dict[str, Any]:
+        return self.validation_registry.get(patch_validation_id).to_dict()
+
+    def list(self, *, patch_id: Optional[str] = None, status: Optional[str] = None, limit: int = 50, offset: int = 0) -> Dict[str, Any]:
+        return self.validation_registry.list(patch_id=patch_id, status=status, limit=limit, offset=offset)
+
+    def _resolve_stored_patch(self, patch_id: str) -> Path:
+        if not patch_id or not patch_id.startswith("PATCH-"):
+            raise ValueError("patch_id must reference a stored PATCH-* artifact")
+        candidates = [
+            self.patch_root / patch_id / "patch.diff",
+            self.patch_root / patch_id / "diff.patch",
+            self.patch_root / patch_id / f"{patch_id}.patch",
+        ]
+        for candidate in candidates:
+            resolved = candidate.resolve()
+            root = self.patch_root.resolve()
+            if root not in resolved.parents:
+                raise ValueError("patch path escaped patch registry root")
+            if candidate.exists() and candidate.is_file():
+                return candidate
+        raise FileNotFoundError(f"stored patch diff not found for {patch_id}")
+
+    def _register_artifact(self, record: PatchValidationRecord) -> Optional[str]:
+        if self.artifact_registry is None:
+            return None
+        result_path = self.validation_registry.root / record.patch_validation_id / "result.json"
+        metadata = {
+            "artifact_category": "patch",
+            "artifact_type": "patch_validation_result",
+            "source_id": record.patch_validation_id,
+            "patch_id": record.patch_id,
+            "status": record.status,
+            "path": str(result_path),
+            "summary": record.summary,
+        }
+        for method_name in ("register", "create", "create_artifact", "register_artifact"):
+            method = getattr(self.artifact_registry, method_name, None)
+            if callable(method):
+                result = method(**metadata)
+                if isinstance(result, dict):
+                    return result.get("artifact_id") or result.get("id")
+                return getattr(result, "artifact_id", None) or getattr(result, "id", None)
+        return None
+
+    def _audit(self, record: PatchValidationRecord, *, context: Optional[WorkerContext]) -> None:
+        if self.audit_sink is None:
+            return
+        payload = {"event_type": "patch.validation", "record": record.to_dict(), "context": self._context_payload(context)}
+        for method_name in ("record", "write", "audit", "append"):
+            method = getattr(self.audit_sink, method_name, None)
+            if callable(method):
+                method(payload)
+                return
+
+    @staticmethod
+    def _context_payload(context: Optional[WorkerContext]) -> Dict[str, Any]:
+        if context is None:
+            return {}
+        return {"project_id": context.project_id, "agent_id": context.agent_id, "session_id": context.session_id, "metadata": dict(context.metadata or {})}
+
+    @staticmethod
+    def _now_iso() -> str:
+        from datetime import datetime, timezone
+
+        return datetime.now(timezone.utc).isoformat()
+
+    @staticmethod
+    def _json_dumps(payload: Dict[str, Any]) -> str:
+        import json
+
+        return json.dumps(payload, indent=2, sort_keys=True)
