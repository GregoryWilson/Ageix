+from __future__ import annotations
+
+import json
+from dataclasses import dataclass, field
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any, Dict, List, Optional
+from uuid import uuid4
+
+
+def _now() -> str:
+    return datetime.now(timezone.utc).isoformat()
+
+
+def _new_patch_validation_id() -> str:
+    return f"PATCHVAL-{uuid4().hex[:12].upper()}"
+
+
+@dataclass(frozen=True)
+class PatchValidationRecord:
+    patch_validation_id: str
+    patch_id: str
+    status: str
+    summary: str
+    artifact_id: Optional[str] = None
+    stdout_tail: str = ""
+    stderr_tail: str = ""
+    exit_code: Optional[int] = None
+    started_at: str = field(default_factory=_now)
+    completed_at: str = field(default_factory=_now)
+    duration_ms: Optional[int] = None
+    metadata: Dict[str, Any] = field(default_factory=dict)
+
+    def to_dict(self) -> Dict[str, Any]:
+        return {
+            "patch_validation_id": self.patch_validation_id,
+            "patch_id": self.patch_id,
+            "status": self.status,
+            "summary": self.summary,
+            "artifact_id": self.artifact_id,
+            "stdout_tail": self.stdout_tail,
+            "stderr_tail": self.stderr_tail,
+            "exit_code": self.exit_code,
+            "started_at": self.started_at,
+            "completed_at": self.completed_at,
+            "duration_ms": self.duration_ms,
+            "metadata": dict(self.metadata or {}),
+        }
+
+    @classmethod
+    def from_dict(cls, payload: Dict[str, Any]) -> "PatchValidationRecord":
+        return cls(
+            patch_validation_id=str(payload["patch_validation_id"]),
+            patch_id=str(payload["patch_id"]),
+            status=str(payload["status"]),
+            summary=str(payload.get("summary") or ""),
+            artifact_id=payload.get("artifact_id"),
+            stdout_tail=str(payload.get("stdout_tail") or ""),
+            stderr_tail=str(payload.get("stderr_tail") or ""),
+            exit_code=payload.get("exit_code"),
+            started_at=str(payload.get("started_at") or _now()),
+            completed_at=str(payload.get("completed_at") or _now()),
+            duration_ms=payload.get("duration_ms"),
+            metadata=dict(payload.get("metadata") or {}),
+        )
+
+
+class PatchValidationRegistry:
+    """Immutable storage for patch validation results.
+
+    Stores metadata in .ageix/patch_validations/index.json and one immutable
+    directory per validation result containing result.json, stdout.txt and
+    stderr.txt.
+    """
+
+    VALID_STATUSES = {"passed", "failed", "error"}
+
+    def __init__(self, root: Path | str = ".ageix/patch_validations") -> None:
+        self.root = Path(root)
+        self.index_path = self.root / "index.json"
+
+    def _ensure(self) -> None:
+        self.root.mkdir(parents=True, exist_ok=True)
+        if not self.index_path.exists():
+            self.index_path.write_text(json.dumps({"validations": []}, indent=2), encoding="utf-8")
+
+    def _read_index(self) -> Dict[str, Any]:
+        self._ensure()
+        try:
+            data = json.loads(self.index_path.read_text(encoding="utf-8"))
+        except json.JSONDecodeError:
+            data = {"validations": []}
+        if not isinstance(data, dict):
+            data = {"validations": []}
+        data.setdefault("validations", [])
+        return data
+
+    def _write_index(self, data: Dict[str, Any]) -> None:
+        self._ensure()
+        tmp = self.index_path.with_suffix(".json.tmp")
+        tmp.write_text(json.dumps(data, indent=2, sort_keys=True), encoding="utf-8")
+        tmp.replace(self.index_path)
+
+    def create(
+        self,
+        *,
+        patch_id: str,
+        status: str,
+        summary: str,
+        stdout: str = "",
+        stderr: str = "",
+        artifact_id: Optional[str] = None,
+        exit_code: Optional[int] = None,
+        started_at: Optional[str] = None,
+        completed_at: Optional[str] = None,
+        duration_ms: Optional[int] = None,
+        metadata: Optional[Dict[str, Any]] = None,
+    ) -> PatchValidationRecord:
+        if status not in self.VALID_STATUSES:
+            raise ValueError(f"invalid patch validation status: {status}")
+        if not patch_id or not str(patch_id).startswith("PATCH-"):
+            raise ValueError("patch_id must reference a stored PATCH-* artifact")
+
+        self._ensure()
+        validation_id = _new_patch_validation_id()
+        validation_dir = self.root / validation_id
+        validation_dir.mkdir(parents=False, exist_ok=False)
+
+        stdout = stdout or ""
+        stderr = stderr or ""
+        record = PatchValidationRecord(
+            patch_validation_id=validation_id,
+            patch_id=patch_id,
+            status=status,
+            summary=summary,
+            artifact_id=artifact_id,
+            stdout_tail=self.tail(stdout),
+            stderr_tail=self.tail(stderr),
+            exit_code=exit_code,
+            started_at=started_at or _now(),
+            completed_at=completed_at or _now(),
+            duration_ms=duration_ms,
+            metadata=dict(metadata or {}),
+        )
+
+        (validation_dir / "stdout.txt").write_text(stdout, encoding="utf-8")
+        (validation_dir / "stderr.txt").write_text(stderr, encoding="utf-8")
+        (validation_dir / "result.json").write_text(
+            json.dumps(record.to_dict(), indent=2, sort_keys=True),
+            encoding="utf-8",
+        )
+
+        index = self._read_index()
+        index["validations"].append(record.to_dict())
+        self._write_index(index)
+        return record
+
+    def get(self, patch_validation_id: str) -> PatchValidationRecord:
+        result_path = self.root / patch_validation_id / "result.json"
+        if not result_path.exists():
+            raise KeyError(f"patch validation not found: {patch_validation_id}")
+        return PatchValidationRecord.from_dict(json.loads(result_path.read_text(encoding="utf-8")))
+
+    def list(self, *, patch_id: Optional[str] = None, status: Optional[str] = None, limit: int = 50, offset: int = 0) -> Dict[str, Any]:
+        index = self._read_index()
+        rows: List[Dict[str, Any]] = list(index.get("validations") or [])
+        if patch_id:
+            rows = [row for row in rows if row.get("patch_id") == patch_id]
+        if status:
+            rows = [row for row in rows if row.get("status") == status]
+        rows.sort(key=lambda row: row.get("completed_at") or "", reverse=True)
+        total = len(rows)
+        return {"validations": rows[offset : offset + limit], "count": min(limit, max(total - offset, 0)), "total_count": total, "limit": limit, "offset": offset}
+
+    @staticmethod
+    def tail(text: str, limit: int = 4000) -> str:
+        text = text or ""
+        return text[-limit:]
