+    status: Literal[
+        "discovery_required",
+        "research_pending",
+        "architecture_pending",
+        "ready_for_planning",
+    ]
+    discovery: DiscoveryResult
+    research_results: list[ResearchResult] = Field(default_factory=list)
+    architecture_review: ArchitectureReview | None = None
